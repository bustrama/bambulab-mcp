# 64-char random string — signs all JWTs (access tokens + PKCE auth codes)
# Generate: openssl rand -base64 48
JWT_SECRET=

# 64-char hex (= 32-byte AES-256 key) — encrypts the Bambu access token
# inside every JWT so the token is never stored server-side in plain text.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Public URL of this deployment — used in OAuth metadata responses.
# Local: http://localhost:3000
# Prod:  https://bambulab-mcp.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
